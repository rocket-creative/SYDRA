{
  "ci": {
    "collect": {
      "startServerCommand": "next start -p 3137",
      "url": [
        "http://localhost:3137/",
        "http://localhost:3137/pricing",
        "http://localhost:3137/idr"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "perf",
        "formFactor": "mobile",
        "throttlingMethod": "simulate",
        "screenEmulation": {
          "mobile": true,
          "width": 390,
          "height": 844,
          "deviceScaleFactor": 3
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 200 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "tests/lighthouse"
    }
  }
}
