# Copy to .env and fill in.
# Direct Postgres connection to the same database the app uses.
# Supabase: Project Settings -> Database -> Connection string (use the direct
# 5432 connection, not the pooler, so psql + the staging migration work).
DATABASE_URL=postgres://postgres:password@db.xxxx.supabase.co:5432/postgres

# Path to a downloaded CMS Federal IDR Public Use File (CSV).
# Get it from: https://www.cms.gov/nosurprises/policies-and-resources/reports
IDR_PUF_PATH=./data/federal-idr-puf-2025H1.csv
IDR_PUF_PERIOD=2025H1

# Path to one payer's Transparency-in-Coverage in-network-rates MRF (.json or .json.gz)
# Found via the payer's public TiC index. MRF_PAYER_SLUG must match a slug in the
# app's idr_payers table (see src/lib/idr/taxonomy.ts IDR_PAYERS).
MRF_PATH=./data/uhc-in-network-rates.json.gz
MRF_PAYER_SLUG=unitedhealthcare
