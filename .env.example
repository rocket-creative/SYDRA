NEXT_PUBLIC_SITE_URL=https://www.sydrahealth.com
NEXT_PUBLIC_CONTACT_EMAIL=sales@kronosrevenue.health
NEXT_PUBLIC_SALES_EMAIL=sales@kronosrevenue.health
NEXT_PUBLIC_SUPPORT_EMAIL=support@sydrahealth.com
NEXT_PUBLIC_KRONOS_REVENUE_URL=https://www.kronosrevenue.health
# Optional display phone, e.g. (555) 123 4567
# NEXT_PUBLIC_CONTACT_PHONE=
# Optional comma separated social profile URLs for Organization sameAs schema
# NEXT_PUBLIC_ORG_SAME_AS=https://www.linkedin.com/company/example,https://twitter.com/example

# Google Ads conversion label for the demo request goal (client).
# The global tag (AW-17987595919) loads on every page regardless. The demo
# conversion only fires once this label is set. Get it from the event snippet
# detail page in Google Ads (the part after the slash in send_to).
# NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=AbCdEfGhIjKlMnOp

# Form lead delivery (server only — set in Vercel, not client)
# All demo and security form submissions go to LEADS_INBOX (sales).
# Submitters receive a confirmation at their work email.
RESEND_API_KEY=
LEADS_FROM_EMAIL=notifications@sydrahealth.com
LEADS_INBOX_EMAIL=sales@kronosrevenue.health

# Postcard landing (server only)
# CRM_WEBHOOK_URL=
# ANALYTICS_WEBHOOK_URL=

# Postcard landing (client)
# NEXT_PUBLIC_SYDRA_CALENDLY_URL=https://calendly.com/kronoshealth/sydra-demo
# NEXT_PUBLIC_KRONOS_CALENDLY_URL=https://calendly.com/kronoshealth/kronos-revenue-case-review
