NEXT_PUBLIC_SITE_URL=https://www.sydrahealth.com
NEXT_PUBLIC_CONTACT_EMAIL=sales@sydrahealth.com
NEXT_PUBLIC_SALES_EMAIL=sales@sydrahealth.com
NEXT_PUBLIC_SUPPORT_EMAIL=sales@sydrahealth.com
NEXT_PUBLIC_KRONOS_REVENUE_URL=https://www.kronosrevenue.health
# Optional display phone, e.g. (555) 123 4567
# NEXT_PUBLIC_CONTACT_PHONE=
# Optional comma separated social profile URLs for Organization sameAs schema
# NEXT_PUBLIC_ORG_SAME_AS=https://www.linkedin.com/company/example,https://twitter.com/example

# Google Ads conversion label for the demo request goal (client).
# The global tag (AW-17987595919) loads on every page regardless. The demo
# conversion only fires once this label is set. Get it from the event snippet
# detail page in Google Ads (the part after the slash in send_to).
# NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=AbCdEfGhIjKlMnOp

# Google Analytics 4 measurement ID (client). Defaults to the live Sydra Web
# stream (G-7KPTH8W6N3) in code, so this only needs setting to override it.
# Demo/lead form submits fire a `generate_lead` event you can mark as a key
# event in GA4. Find the ID in GA4 Admin > Data streams (starts with G-).
# NEXT_PUBLIC_GA4_ID=G-7KPTH8W6N3

# Google Search Console HTML-tag verification token (client). Only needed if you
# verify by meta tag instead of the DNS TXT record. Paste just the content value
# from the google-site-verification meta tag GSC gives you.
# NEXT_PUBLIC_GSC_VERIFICATION=

# Form lead delivery (server only — set in Vercel, not client)
# All demo and security form submissions go to LEADS_INBOX (sales).
# Submitters receive a confirmation at their work email.
RESEND_API_KEY=
LEADS_FROM_EMAIL=notifications@sydrahealth.com
LEADS_INBOX_EMAIL=sales@sydrahealth.com

# Postcard landing (server only)
# CRM_WEBHOOK_URL=
# ANALYTICS_WEBHOOK_URL=

# Postcard landing (client)
# NEXT_PUBLIC_SYDRA_CALENDLY_URL=https://calendly.com/kronoshealth/sydra-demo
# NEXT_PUBLIC_KRONOS_CALENDLY_URL=https://calendly.com/kronoshealth/kronos-revenue-case-review

# Entity-SEO data layer (Supabase). When unset, /idr pages render from the
# in-repo seed dataset (all noindex). Set these once the schema is migrated and
# seeded to read benchmark data from Postgres.
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_ANON_KEY=
# Service role is server only — never expose to the client. Used for reads and
# by the seed script (supabase/seed.ts) for writes.
# SUPABASE_SERVICE_ROLE_KEY=
